{
  "version": 1,
  "blocks": [
    {
      "id": "wan22_video_output",
      "when": { "engines": ["wan22"], "tabs": ["txt2vid", "img2vid"] },
      "layout": { "columns": 3 },
      "fields": [
        { "key": "video.filename_prefix", "label": "Filename Prefix", "type": "text", "default": "wan22", "bind": { "txt2vid": "filenamePrefix", "img2vid": "filenamePrefix" } },
        { "key": "video.format", "label": "Format", "type": "select", "options": ["video/h264-mp4", "video/h265-mp4", "video/gif"], "default": "video/h264-mp4", "bind": { "txt2vid": "videoFormat", "img2vid": "videoFormat" } },
        { "key": "video.pix_fmt", "label": "Pixel Format", "type": "select", "options": ["yuv420p", "yuv444p", "yuv422p"], "default": "yuv420p", "bind": { "txt2vid": "videoPixFormat", "img2vid": "videoPixFormat" } },
        { "key": "video.crf", "label": "CRF", "type": "number", "min": 0, "max": 51, "default": 15, "bind": { "txt2vid": "videoCrf", "img2vid": "videoCrf" } },
        { "key": "video.loop_count", "label": "Loop Count", "type": "number", "min": 0, "max": 100, "default": 0, "bind": { "txt2vid": "videoLoopCount", "img2vid": "videoLoopCount" } },
        { "key": "video.pingpong", "label": "Ping-pong", "type": "checkbox", "default": false, "bind": { "txt2vid": "videoPingpong", "img2vid": "videoPingpong" } }
      ]
    },
    {
      "id": "wan22_models",
      "when": { "engines": ["wan22"], "tabs": ["txt2vid", "img2vid"] },
      "layout": { "columns": 2 },
      "fields": [
        { "key": "wan.high.model_sha", "label": "High Model (sha256)", "type": "text", "help": "64-hex sha256 resolving to a .gguf file (from inventory)", "bind": { "txt2vid": "hiModelSha", "img2vid": "hiModelSha" } },
        { "key": "wan.low.model_sha", "label": "Low Model (sha256)", "type": "text", "help": "64-hex sha256 resolving to a .gguf file (from inventory)", "bind": { "txt2vid": "loModelSha", "img2vid": "loModelSha" } },
        { "key": "wan.high.loras", "label": "High LoRAs (JSON array)", "type": "textarea", "default": "[]", "help": "Optional JSON array of {sha, weight} entries; backend rejects legacy lora_sha/lora_weight." },
        { "key": "wan.low.loras", "label": "Low LoRAs (JSON array)", "type": "textarea", "default": "[]", "help": "Optional JSON array of {sha, weight} entries; backend rejects legacy lora_sha/lora_weight." }
      ]
    },
    {
      "id": "wan22_rife",
      "when": { "engines": ["wan22"], "tabs": ["txt2vid", "img2vid"] },
      "layout": { "columns": 2 },
      "fields": [
        { "key": "video.interpolation.enabled", "label": "Enable Interpolation", "type": "checkbox", "default": true, "bind": { "txt2vid": "rifeEnabled", "img2vid": "rifeEnabled" } },
        { "key": "video.interpolation.model", "label": "Model", "type": "text", "default": "rife47.pth", "bind": { "txt2vid": "rifeModel", "img2vid": "rifeModel" }, "visibleIf": { "video.interpolation.enabled": true } },
        { "key": "video.interpolation.times", "label": "Times", "type": "number", "min": 1, "max": 8, "default": 2, "bind": { "txt2vid": "rifeTimes", "img2vid": "rifeTimes" }, "visibleIf": { "video.interpolation.enabled": true } }
      ]
    },
    {
      "id": "svd_basic",
      "when": { "engines": ["svd"], "tabs": ["img2vid"] },
      "layout": { "columns": 2 },
      "fields": [
        { "key": "video.filename_prefix", "label": "Filename Prefix", "type": "text", "default": "svd", "bind": { "img2vid": "filenamePrefix" } },
        { "key": "video.format", "label": "Format", "type": "select", "options": ["video/h264-mp4", "video/webm"], "default": "video/h264-mp4", "bind": { "img2vid": "videoFormat" } },
        { "key": "video.pix_fmt", "label": "Pixel Format", "type": "select", "options": ["yuv420p"], "default": "yuv420p", "bind": { "img2vid": "videoPixFormat" } },
        { "key": "video.crf", "label": "CRF", "type": "number", "min": 0, "max": 51, "default": 23, "bind": { "img2vid": "videoCrf" } }
      ]
    },
    {
      "id": "hunyuan_basic",
      "when": { "engines": ["hunyuan_video"], "tabs": ["txt2vid", "img2vid"] },
      "layout": { "columns": 2 },
      "fields": [
        { "key": "video.filename_prefix", "label": "Filename Prefix", "type": "text", "default": "hunyuan", "bind": { "txt2vid": "filenamePrefix", "img2vid": "filenamePrefix" } },
        { "key": "video.format", "label": "Format", "type": "select", "options": ["video/h264-mp4"], "default": "video/h264-mp4", "bind": { "txt2vid": "videoFormat", "img2vid": "videoFormat" } },
        { "key": "video.pix_fmt", "label": "Pixel Format", "type": "select", "options": ["yuv420p"], "default": "yuv420p", "bind": { "txt2vid": "videoPixFormat", "img2vid": "videoPixFormat" } },
        { "key": "video.crf", "label": "CRF", "type": "number", "min": 0, "max": 51, "default": 23, "bind": { "txt2vid": "videoCrf", "img2vid": "videoCrf" } }
      ]
    }
  ]
}
