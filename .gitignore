# Stable Diffusion WebUI Codex — ignore policy lives in `gitignore.md`.

# OS / editors
.DS_Store
*:Zone.Identifier
.vscode/
.idea/

# Python
__pycache__/
.pytest_cache/
/.venv/

# uv (repo-local installer + managed CPython installs)
/.uv/

# nodeenv (repo-local Node.js install for the frontend)
/.nodeenv/

# Local dev caches (do not commit)
/.tmp/
/.npm-cache/
/.ts-out/
/artifacts/

# Reference snapshots (kept local; not in Git)
/.refs/

# Backend runtime state / outputs (do not commit)
/output/
/logs/
.webui-*.log
.webui-*.pid
/trace.json

# Root scratch (do not commit)
/*.png
!/logo.png
/*.txt

# Deprecated stash (do not commit; see `gitignore.md`)
/.deprecated/

# Local one-off configs/scripts (do not commit)
/config.json
/ui-config.json
/script-gemini*.js
/HAR-fetch.json

# Frontend artifacts (Vue/Vite)
node_modules/
apps/interface/dist/
apps/interface/.vite/
apps/interface/.eslintcache
apps/interface/.pnpm-debug.log
apps/interface/.reports/css-contract-report.json

# Local runtime state (do not commit)
apps/interface/tabs.json
apps/interface/workflows.json
apps/settings_values.json

# Sangoi project docs / dev tooling (lives in separate repo; keep local checkout here)
/.sangoi/

# No binary office docs
*.docx

# Model weights / large artifacts (never commit)
/models/
*.ckpt
*.safetensors
*.pth

# Guardrails
# If you add broad ignores like `*.txt`/`*.png`, keep them above this block.
!apps/**/*.txt
!apps/**/*.png
